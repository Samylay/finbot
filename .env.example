# Copier ce fichier en .env et remplir les valeurs

# OpenAI – obligatoire
OPENAI_API_KEY=sk-...

# Tavily – obligatoire pour A3 (recherche web)
# Compte gratuit sur https://tavily.com
TAVILY_API_KEY=tvly-...

# PostgreSQL – obligatoire pour D1
DATABASE_URL=postgresql://user:password@localhost:5432/finbot
